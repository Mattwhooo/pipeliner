<% content_for :title, "New project · Pipeliner" %>

<div class="mx-auto max-w-3xl">
  <h1 class="text-2xl font-semibold text-default">New project</h1>
  <p class="mt-1 text-sm text-muted">A project is tied to a single git repository.</p>

  <%= form_with model: @project, class: "mt-8 space-y-4" do |f| %>
    <% if @project.errors.any? %>
      <div class="rounded-md bg-red-50 px-4 py-3 text-sm text-red-700 ring-1 ring-red-600/20 dark:bg-red-500/10 dark:text-red-400 dark:ring-red-400/20">
        <ul class="list-inside list-disc">
          <% @project.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-default" %>
      <%= f.text_field :name,
            class: "mt-1 block w-full rounded-md border-0 px-3 py-1.5 text-sm text-default ring-1 ring-inset ring-default focus:ring-2 focus:ring-indigo-600" %>
    </div>

    <div>
      <%= f.label :repo_url, "Repository URL", class: "block text-sm font-medium text-default" %>
      <%= f.text_field :repo_url, placeholder: "https://github.com/org/repo",
            class: "mt-1 block w-full rounded-md border-0 px-3 py-1.5 font-mono text-sm text-default ring-1 ring-inset ring-default focus:ring-2 focus:ring-indigo-600" %>
      <p class="mt-1 text-xs text-muted">All of this project's pipelines target this repo.</p>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :default_branch, class: "block text-sm font-medium text-default" %>
        <%= f.text_field :default_branch,
              class: "mt-1 block w-full rounded-md border-0 px-3 py-1.5 font-mono text-sm text-default ring-1 ring-inset ring-default focus:ring-2 focus:ring-indigo-600" %>
      </div>
      <div>
        <%= f.label :project_type, class: "block text-sm font-medium text-default" %>
        <%= f.select :project_type, [ [ "Software", "software" ], [ "Wiki", "wiki" ] ],
              {}, class: "mt-1 block w-full rounded-md border-0 px-3 py-1.5 text-sm text-default ring-1 ring-inset ring-default focus:ring-2 focus:ring-indigo-600" %>
        <p class="mt-1 text-xs text-muted">Selects the default step template pack.</p>
      </div>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit "Create project",
            class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer" %>
      <%= link_to "Cancel", projects_path, class: "text-sm font-medium text-muted hover:text-default" %>
    </div>
  <% end %>
</div>
