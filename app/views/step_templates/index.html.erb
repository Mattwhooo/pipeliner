<% content_for :title, "Step Library · Pipeliner" %>

<div class="flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-semibold text-gray-900">Step Library</h1>
    <p class="mt-1 text-sm text-gray-500">Reusable step templates you can compose into workflows.</p>
  </div>
  <%= link_to "New template", new_step_template_path,
        class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700" %>
</div>

<div class="mt-8 overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
  <table class="min-w-full divide-y divide-gray-100">
    <thead>
      <tr>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500">Name</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500">Type</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500">Role</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500">Usage</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @templates.each do |template| %>
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4">
            <div class="text-sm font-medium text-gray-900"><%= template.name %></div>
            <div class="mt-0.5 line-clamp-1 text-xs text-gray-500"><%= template.system_prompt %></div>
          </td>
          <td class="px-6 py-4">
            <span class="rounded bg-gray-100 px-1.5 py-0.5 text-xs font-medium text-gray-700"><%= template.step_type %></span>
          </td>
          <td class="px-6 py-4 font-mono text-xs text-gray-600"><%= template.role %></td>
          <td class="px-6 py-4 text-xs text-gray-500"><%= template.requirement %></td>
          <td class="px-6 py-4 text-right text-sm">
            <%= link_to "Edit", edit_step_template_path(template),
                  class: "font-medium text-indigo-600 hover:text-indigo-700" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
