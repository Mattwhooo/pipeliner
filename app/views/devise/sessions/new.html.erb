<% content_for :title, "Sign in · Pipeliner" %>

<h2 class="text-lg font-semibold text-gray-900">Sign in</h2>

<%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-6 space-y-4" }) do |f| %>
  <div>
    <%= f.label :email, class: "block text-sm font-medium text-gray-900" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email",
          class: "mt-1 block w-full rounded-md px-3 py-1.5 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 border-0 focus:ring-2 focus:ring-indigo-600" %>
  </div>

  <div>
    <%= f.label :password, class: "block text-sm font-medium text-gray-900" %>
    <%= f.password_field :password, autocomplete: "current-password",
          class: "mt-1 block w-full rounded-md px-3 py-1.5 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 border-0 focus:ring-2 focus:ring-indigo-600" %>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="flex items-center gap-2">
      <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600" %>
      <%= f.label :remember_me, class: "text-sm text-gray-700" %>
    </div>
  <% end %>

  <%= f.submit "Sign in",
        class: "w-full rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700 focus-visible:ring-2 focus-visible:ring-indigo-600 cursor-pointer" %>
<% end %>

<div class="mt-4 text-center text-xs text-gray-500">
  <%= render "devise/shared/links" %>
</div>
