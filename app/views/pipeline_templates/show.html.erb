<% content_for :title, "Pipeline template · #{@project.name} · Pipeliner" %>

<nav class="text-xs text-gray-500">
  <%= link_to @project.name, @project, class: "hover:text-gray-900" %>
  <span class="mx-1">/</span>
  <span class="text-gray-900">Pipeline template</span>
</nav>

<div class="mt-2">
  <h1 class="text-2xl font-semibold text-gray-900">Pipeline template</h1>
  <p class="mt-1 text-sm text-gray-500">
    The steps every pipeline of <span class="font-medium text-gray-900"><%= @project.name %></span>
    always includes. Changes apply to pipelines created from now on.
  </p>
</div>

<div class="mt-6 rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
  <%= form_with model: @template, url: project_pipeline_template_path(@project),
        method: :patch, class: "flex items-center justify-between gap-4" do |f| %>
    <div>
      <p class="text-sm font-medium text-gray-900">Manager additions</p>
      <p class="mt-1 text-xs text-gray-500">
        When enabled, the Workflow Composer may add steps beyond the pinned set for
        tasks that need them (e.g. UI testing). When disabled, pipelines contain
        exactly the pinned steps.
      </p>
    </div>
    <div class="flex shrink-0 items-center gap-3">
      <%= f.check_box :allow_manager_additions,
            class: "h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600" %>
      <%= f.label :allow_manager_additions, "Allow", class: "text-sm text-gray-700" %>
      <%= f.submit "Save",
            class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer" %>
    </div>
  <% end %>
</div>

<div class="mt-8 space-y-8">
  <% Phase::KINDS_IN_ORDER.each do |kind| %>
    <% entries = @template.entries_for(kind).includes(:step_template).order(:position) %>
    <% pinned_ids = entries.map(&:step_template_id) %>
    <% available = StepTemplate.available_to(@project).for_phase(kind).order(:name)
         .reject { |t| pinned_ids.include?(t.id) } %>
    <section>
      <h2 class="text-lg font-semibold text-gray-900"><%= kind.humanize %></h2>
      <% if kind == "define" %>
        <p class="mt-1 text-xs text-gray-500">Define runs the same core for every pipeline; custom Define steps run late in the phase.</p>
      <% end %>

      <div class="mt-3 overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
        <% if entries.any? %>
          <ul class="divide-y divide-gray-100">
            <% entries.each_with_index do |entry, index| %>
              <li class="flex items-center gap-3 px-6 py-3">
                <span class="w-5 text-xs text-gray-400"><%= index + 1 %></span>
                <div class="min-w-0 flex-1">
                  <span class="text-sm font-medium text-gray-900"><%= entry.step_template.name %></span>
                  <span class="ml-2 rounded bg-gray-100 px-1.5 py-0.5 text-xs font-medium text-gray-700"><%= entry.step_template.step_type %></span>
                  <% if entry.step_template.role.present? %>
                    <span class="ml-1 font-mono text-xs text-gray-500"><%= entry.step_template.role %></span>
                  <% end %>
                </div>
                <div class="flex shrink-0 items-center gap-2 text-sm">
                  <% unless index.zero? %>
                    <%= button_to "↑", move_project_pipeline_template_step_path(@project, entry, direction: "up"),
                          class: "rounded px-1.5 py-0.5 text-gray-400 hover:bg-gray-100 hover:text-gray-700 bg-transparent cursor-pointer",
                          form: { class: "inline" }, "aria-label": "Move up" %>
                  <% end %>
                  <% unless index == entries.size - 1 %>
                    <%= button_to "↓", move_project_pipeline_template_step_path(@project, entry, direction: "down"),
                          class: "rounded px-1.5 py-0.5 text-gray-400 hover:bg-gray-100 hover:text-gray-700 bg-transparent cursor-pointer",
                          form: { class: "inline" }, "aria-label": "Move down" %>
                  <% end %>
                  <%= button_to "Unpin", project_pipeline_template_step_path(@project, entry),
                        method: :delete,
                        class: "text-xs font-medium text-red-600 hover:text-red-700 bg-transparent cursor-pointer",
                        form: { class: "inline", data: { turbo_confirm: "Unpin #{entry.step_template.name} from #{kind.humanize}?" } } %>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="px-6 py-6 text-center text-xs text-gray-400">
            No pinned steps — <%= kind == "build" || kind == "review" ? "the Workflow Composer decides this phase entirely." : "this phase starts empty." %>
          </p>
        <% end %>

        <% if available.any? %>
          <div class="border-t border-gray-100 bg-gray-50/60 px-6 py-3">
            <%= form_with url: project_pipeline_template_steps_path(@project),
                  scope: :pipeline_template_step, class: "flex items-center gap-3" do |f| %>
              <%= f.hidden_field :phase, value: kind %>
              <%= f.select :step_template_id,
                    options_from_collection_for_select(available, :id, :name), {},
                    class: "block w-64 rounded-md border-0 px-3 py-1.5 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-indigo-600" %>
              <%= f.submit "Pin step",
                    class: "rounded-md bg-white px-3 py-1.5 text-sm font-semibold text-gray-900 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 cursor-pointer" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
