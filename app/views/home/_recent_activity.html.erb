<div id="recent-activity" class="rounded-lg border border-gray-200 bg-white shadow-sm">
  <div class="border-b border-gray-100 px-6 py-4">
    <h2 class="text-lg font-semibold text-gray-900">Recent activity</h2>
  </div>

  <% if events.any? %>
    <div class="divide-y divide-gray-100">
      <% events.each do |event| %>
        <%= render "home/activity_item", event: event %>
      <% end %>
    </div>
  <% else %>
    <div class="py-12 text-center">
      <p class="text-sm font-medium text-gray-900">No recent activity</p>
      <p class="mt-1 text-xs text-gray-500">Notable events across your pipelines will show up here.</p>
    </div>
  <% end %>
</div>
