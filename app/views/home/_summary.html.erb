<div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
  <div class="rounded-lg border border-default bg-surface p-6 shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-wide text-subtle">Active pipelines</p>
    <p class="mt-2 text-2xl font-semibold text-default"><%= active.total_count %></p>
  </div>
  <div class="rounded-lg border border-default bg-surface p-6 shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-wide text-subtle">Need attention</p>
    <p class="mt-2 text-2xl font-semibold <%= active.attention_count > 0 ? "text-amber-600" : "text-default" %>">
      <%= active.attention_count %>
    </p>
  </div>
  <div class="rounded-lg border border-default bg-surface p-6 shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-wide text-subtle">Workers online</p>
    <p class="mt-2 text-2xl font-semibold text-default"><%= fleet[:online_count] %></p>
  </div>
</div>
