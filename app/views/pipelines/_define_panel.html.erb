<%# Define is a full-width pre-phase panel (not a board column). Its root id
    matches the phase-column target so Phases::BroadcastColumn can replace it. %>
<div id="<%= dom_id(phase, :column) %>">
  <% if phase.approved? %>
    <% approval = phase.approvals.order(:id).last %>
    <div class="flex items-center gap-2 rounded-lg border border-default bg-app px-4 py-2 text-xs text-muted">
      <span class="font-medium text-muted">Defined</span>
      <span class="text-green-600" aria-hidden="true">✓</span>
      <% if approval %>
        <span>· approved by <%= approval.user.email.split("@").first %></span>
        <span>·</span>
        <time title="<%= approval.created_at %>"><%= time_ago_in_words(approval.created_at) %> ago</time>
      <% end %>
      <%= link_to "view details →", phase_path(phase),
            class: "ml-auto font-medium text-muted hover:text-default" %>
    </div>
  <% else %>
    <% at_gate = phase.status.in?(%w[consensus awaiting_human]) && phase.gate_human? %>
    <% questions = define_open_questions(phase) %>
    <% discovery = define_discovery_notes(phase) %>
    <% requirements = define_business_requirements(phase) %>
    <% summary = define_summary(phase) %>
    <% pending_feedback = define_pending_human_feedback(phase) %>
    <% steps = phase.workflows.flat_map(&:steps) %>
    <% menu_busy = phase.paused? && phase.any_step_active? %>
    <div class="rounded-lg border bg-surface p-6 shadow-sm
                <%= at_gate ? "border-amber-300 ring-1 ring-amber-100 dark:border-amber-500/40 dark:ring-amber-500/10"
                    : (phase.paused? ? "border-amber-300 ring-1 ring-amber-100 dark:border-amber-500/40 dark:ring-amber-500/10"
                    : (phase.kind == current_phase_kind ? "border-indigo-300 ring-1 ring-indigo-100 dark:border-indigo-500/40 dark:ring-indigo-500/10" : "border-default")) %>">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span class="text-xs uppercase tracking-wide text-subtle">Pre-phase</span>
          <h2 class="text-lg font-semibold text-default">Definition</h2>
        </div>
        <div class="flex items-center gap-3">
          <%= status_badge(phase.status) %>
          <% if phase.running? && !phase.restart_in_progress? && !phase.pause_requested? %>
            <%= button_to "Pause", pause_phase_path(phase),
                  class: "text-xs font-medium text-muted underline hover:text-default" %>
          <% end %>
        </div>
      </div>

      <% if phase.running? && phase.pause_requested? && !phase.restart_in_progress? %>
        <p class="mt-3 text-xs text-muted" aria-live="polite">
          Pausing — finishing the current step, then Define will hold for you.
        </p>
      <% end %>

      <% if phase.running? && phase.restart_in_progress? %>
        <div class="mt-4 rounded-md bg-blue-50 p-4 ring-1 ring-inset ring-blue-600/20">
          <p class="text-sm font-medium text-blue-800" aria-live="polite">
            Restarting Define from the beginning — this runs every step again.
            You'll land back on the paused menu with fresh results when it's done.
          </p>
        </div>
      <% elsif phase.paused? && menu_busy %>
        <div class="mt-4 rounded-md bg-blue-50 p-4 ring-1 ring-inset ring-blue-600/20">
          <p class="text-sm font-medium text-blue-800" aria-live="polite">
            Re-running — the menu will come back once this finishes.
          </p>
        </div>
      <% elsif phase.paused? %>
        <div class="mt-4 rounded-md bg-amber-50 p-4 ring-1 ring-inset ring-amber-600/20">
          <p class="text-sm font-medium text-amber-800">Define is paused — choose what to do next.</p>
          <% if (failure = define_menu_failure(phase)) %>
            <div class="mt-2 flex items-start gap-2 text-sm text-red-700">
              <%= status_badge("failed", label: "Re-run failed") %>
              <span><%= failure %></span>
            </div>
          <% end %>
          <div class="mt-3 flex flex-wrap gap-2">
            <% if steps.any? { |s| Array(s.outputs).any? { |o| o["artifact"] == "discovery_notes" } } %>
              <%= button_to "Explore", rerun_step_phase_path(phase, artifact: "discovery_notes"),
                    class: "rounded-md bg-surface px-3 py-2 text-sm font-semibold text-default ring-1 ring-inset ring-default hover:bg-surface-hover",
                    data: { turbo_submits_with: "Starting…" } %>
            <% end %>
            <% if steps.any? { |s| Array(s.outputs).any? { |o| o["artifact"] == "open_questions" } } %>
              <%= button_to "Clarifying Questions", rerun_step_phase_path(phase, artifact: "open_questions"),
                    class: "rounded-md bg-surface px-3 py-2 text-sm font-semibold text-default ring-1 ring-inset ring-default hover:bg-surface-hover",
                    data: { turbo_submits_with: "Starting…" } %>
            <% end %>
            <a href="#define-ask-human"
               class="rounded-md bg-surface px-3 py-2 text-sm font-semibold text-default ring-1 ring-inset ring-default hover:bg-surface-hover">Ask Human</a>
            <%= button_to "Repeat from the Beginning", restart_phase_path(phase),
                  class: "rounded-md bg-surface px-3 py-2 text-sm font-semibold text-default ring-1 ring-inset ring-default hover:bg-surface-hover",
                  data: { turbo_confirm: "Restart Define from the first step? This replaces the current discovery notes and requirements with fresh output.",
                          turbo_submits_with: "Restarting…" } %>
            <%= form_with url: phase_approval_path(phase), class: "inline" do |f| %>
              <%= f.submit "Done", class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer",
                    data: { turbo_submits_with: "Finishing…" } %>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# Human Feedback step in flight — the primary call to action: answer the
          open questions Clarifying Questions raised, each in its own field. %>
      <% if pending_feedback %>
        <% hf_questions = define_open_questions_structured(phase) %>
        <div class="mt-4 rounded-md border border-amber-300 bg-amber-50 p-4 ring-1 ring-inset ring-amber-600/20 dark:border-amber-500/40 dark:bg-amber-500/10 dark:ring-amber-400/20">
          <h3 class="text-sm font-semibold text-amber-900 dark:text-amber-200">Your input needed</h3>
          <p class="mt-1 text-xs text-amber-800 dark:text-amber-300">
            Answer what you can — leave a question blank to accept its stated default.
            Submitting continues Define.
          </p>
          <%= form_with url: submit_feedback_phase_path(phase), class: "mt-4 space-y-4" do |f| %>
            <% if hf_questions.present? %>
              <% hf_questions.each_with_index do |q, i| %>
                <div>
                  <%= label_tag "hf_answer_#{i}", q["question"], class: "block text-sm font-medium text-default" %>
                  <%= hidden_field_tag "question[]", q["question"] %>
                  <%= text_field_tag "answer[]", nil, id: "hf_answer_#{i}", placeholder: q["default"],
                        class: "mt-1 block w-full rounded-md border-0 px-3 py-2 text-sm text-default ring-1 ring-inset ring-default focus:ring-2 focus:ring-indigo-600 bg-surface" %>
                </div>
              <% end %>
            <% else %>
              <p class="text-sm text-amber-800 dark:text-amber-300">
                No structured questions were captured — add any notes below.
              </p>
            <% end %>
            <div>
              <%= label_tag :notes, "Notes (optional)", class: "block text-sm font-medium text-default" %>
              <%= text_area_tag :notes, nil, rows: 3, placeholder: "Anything else the agent should take into account",
                    class: "mt-1 block w-full rounded-md border-0 px-3 py-2 text-sm text-default ring-1 ring-inset ring-default focus:ring-2 focus:ring-indigo-600 bg-surface" %>
            </div>
            <%= f.submit "Submit answers",
                  class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer",
                  data: { turbo_submits_with: "Submitting…" } %>
          <% end %>
        </div>
      <% end %>

      <% if at_gate %>
        <div class="mt-4 rounded-md bg-amber-50 p-4 ring-1 ring-inset ring-amber-600/20">
          <p class="text-sm font-medium text-amber-800">
            <% if phase.consensus? %>
              Consensus reached — review the summary below, then approve to move on.
            <% else %>
              Iteration cap hit — review the summary below, then approve anyway.
            <% end %>
          </p>
          <%= form_with url: phase_approval_path(phase), class: "mt-3 flex items-end gap-2" do |f| %>
            <div class="flex-1">
              <%= f.label :note, "Approval note (optional)", class: "sr-only" %>
              <%= f.text_field :note, placeholder: "Note (optional)",
                    class: "block w-full rounded-md border-0 px-3 py-1.5 text-sm text-default ring-1 ring-inset ring-amber-600/30 focus:ring-2 focus:ring-indigo-600 bg-surface" %>
            </div>
            <%= f.submit phase.consensus? ? "Approve Define" : "Approve anyway",
                  class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer" %>
          <% end %>
          <%= link_to "Review & approve →", phase_path(phase),
                class: "mt-2 inline-block text-sm font-medium text-amber-800 hover:text-amber-900" %>
        </div>
      <% end %>

      <div class="mt-4">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-subtle">Steps</h3>
        <% if steps.any? %>
          <div class="mt-2 grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3">
            <% steps.each do |step| %>
              <%= render "pipelines/step_card", step: step %>
            <% end %>
          </div>
        <% else %>
          <p class="mt-2 text-xs text-subtle">No steps yet.</p>
        <% end %>
      </div>

      <% if summary.present? %>
        <div class="mt-6 border-t border-default pt-6">
          <h3 class="text-sm font-semibold text-default">Define summary</h3>
          <p class="mt-1 text-xs text-muted">What was decided and everything the work must satisfy — approve Define off this.</p>
          <div class="mt-2 space-y-1 rounded-md bg-app p-4 text-sm text-default"><%= simple_format(summary) %></div>
        </div>
      <% end %>

      <% if discovery.present? %>
        <div class="mt-6 border-t border-default pt-6">
          <h3 class="text-sm font-semibold text-default">Discovery notes</h3>
          <div class="mt-2 space-y-1 text-sm text-default"><%= simple_format(discovery) %></div>
        </div>
      <% end %>

      <% if requirements.present? %>
        <div class="mt-6 border-t border-default pt-6">
          <h3 class="text-sm font-semibold text-default">Requirements</h3>
          <div class="mt-2 space-y-1 text-sm text-default"><%= simple_format(requirements) %></div>
        </div>
      <% end %>

      <% if questions.present? || phase.paused? %>
        <div id="define-ask-human" class="mt-6 border-t border-default pt-6">
          <h3 class="text-sm font-semibold text-default">Open questions</h3>
          <% if questions.present? %>
            <div class="mt-2 space-y-1 text-sm text-default"><%= simple_format(questions) %></div>
          <% else %>
            <p class="mt-2 text-sm text-muted">
              No open questions right now — you can still send notes for the agent to take into account.
            </p>
          <% end %>
          <% if phase.paused? %>
            <%= form_with url: answers_phase_path(phase), class: "mt-4 space-y-3" do |f| %>
              <div>
                <%= f.label :answers, questions.present? ? "Your answers" : "Notes for the agent",
                      class: "block text-sm font-medium text-default" %>
                <%= f.text_area :answers, rows: 4, required: true,
                      placeholder: questions.present? ? "Answer by number — unanswered questions use their stated defaults" : "Anything you want the agent to take into account",
                      class: "mt-1 block w-full rounded-md border-0 px-3 py-2 text-sm text-default ring-1 ring-inset ring-default focus:ring-2 focus:ring-indigo-600 bg-surface" %>
                <p class="mt-1 text-xs text-muted">Sending re-opens the requirements loop for another pass.</p>
              </div>
              <%= f.submit "Send answers",
                    class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer",
                    data: { turbo_submits_with: "Sending…" } %>
            <% end %>
          <% else %>
            <p class="mt-2 text-xs text-muted">Answer these from the dashboard.</p>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
