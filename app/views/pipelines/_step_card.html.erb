<%# Smallest live-updating unit on the board: one step's card. %>
<% run = step.latest_run %>
<div id="<%= dom_id(step, :card) %>" class="rounded-md border border-gray-200 bg-white p-3">
  <div class="flex items-center justify-between gap-2">
    <span class="truncate text-sm font-medium text-gray-900"><%= step.slug.humanize %></span>
    <%= status_badge(run&.state || "pending") %>
  </div>
  <div class="mt-2 flex items-center gap-2 text-xs text-gray-500">
    <span class="rounded bg-gray-100 px-1.5 py-0.5 font-medium"><%= step.step_type %></span>
    <% if step.role.present? %>
      <span class="font-mono"><%= step.role %></span>
    <% end %>
    <% if run && run.iteration > 1 %>
      <span class="ml-auto rounded-full bg-gray-100 px-1.5 py-0.5 font-medium" title="Iteration <%= run.iteration %>">×<%= run.iteration %></span>
    <% end %>
  </div>
  <% if run&.state == "running" && run.progress.present? %>
    <p class="mt-2 truncate text-xs text-blue-700" aria-live="polite">
      <%= run.progress["message"] %>
    </p>
  <% end %>
  <% if run&.worker && run.state.in?(%w[claimed running]) %>
    <p class="mt-1 truncate text-xs text-gray-400"><%= run.worker.name || run.worker.public_id %></p>
  <% end %>
  <% if step.worker_executed? && (run.nil? || run.state.in?(%w[succeeded failed stuck])) %>
    <%= link_to run.nil? ? "Queue run" : "Re-run",
          queue_run_step_path(step), data: { turbo_method: :post },
          class: "mt-2 inline-block text-xs font-medium text-indigo-600 hover:text-indigo-700" %>
  <% end %>
</div>
