<%# Live "what is happening right now" summary for a pipeline. One source of
    truth for both surfaces: the full card on the board (show) and the compact
    line on the list (index) render the SAME derived value, so they can never
    disagree about the state (R18). `dom_id(pipeline, :summary)` is the stable
    Turbo target; `aria-live="polite"` makes it a live region for assistive tech.
    Status is conveyed by the words — the dot only reinforces the tone (R17). %>
<% summary = Pipelines::StatusSummary.for(pipeline) %>
<% compact = local_assigns.fetch(:compact, false) %>

<% if compact %>
  <div id="<%= dom_id(pipeline, :summary) %>" aria-live="polite" class="flex items-center gap-2">
    <span class="h-2 w-2 shrink-0 rounded-full <%= summary_dot_class(summary.tone) %>" aria-hidden="true"></span>
    <span class="truncate text-sm text-gray-700"><%= summary.text %></span>
  </div>
<% else %>
  <div id="<%= dom_id(pipeline, :summary) %>" aria-live="polite"
       class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <% if summary.phase_label.present? %>
      <p class="text-xs uppercase tracking-wide text-gray-400"><%= summary.phase_label %></p>
    <% end %>
    <div class="mt-1 flex items-center gap-2">
      <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= summary_dot_class(summary.tone) %>" aria-hidden="true"></span>
      <p class="text-sm font-medium text-gray-900"><%= summary.text %></p>
    </div>
  </div>
<% end %>
