<% content_for :title, "#{@pipeline.title} · Pipeliner" %>

<nav class="text-xs text-muted">
  <%= link_to @pipeline.project.name, @pipeline.project, class: "hover:text-default" %>
  <span class="mx-1">/</span>
  <span class="text-default"><%= @pipeline.title %></span>
</nav>

<div class="mt-2 flex items-center justify-between">
  <div>
    <div class="flex items-center gap-3">
      <h1 class="text-2xl font-semibold text-default"><%= @pipeline.title %></h1>
      <%= status_badge(@pipeline.status) %>
    </div>
    <p class="mt-1 font-mono text-xs text-muted"><%= @pipeline.branch %></p>
  </div>
</div>

<%= turbo_stream_from @pipeline %>

<%# The first status on the page: a single plain-language line for what is
    happening right now, above the per-step cards (R1). %>
<div class="mt-6">
  <%= render "pipelines/status_summary", pipeline: @pipeline, compact: false %>
</div>

<%# Post-finalization: a real PR (or compare-link fallback) is open, so surface
    the Review / Merge / Update-from-main actions. %>
<% if @pipeline.pr_url.present? %>
  <div class="mt-6">
    <%= render "pipelines/actions", pipeline: @pipeline %>
  </div>
<% end %>

<% if @pipeline.initial_prompt.present? %>
  <div class="mt-6 rounded-lg border border-default bg-surface p-6 shadow-sm">
    <h2 class="text-xs font-semibold uppercase tracking-wide text-subtle">The ask</h2>
    <p class="mt-2 whitespace-pre-line text-sm text-muted"><%= @pipeline.initial_prompt %></p>
  </div>
<% end %>

<% define_phase = @phases.find(&:define_phase?) %>
<% downstream_phases = @phases.reject(&:define_phase?) %>

<% if define_phase %>
  <div class="mt-8">
    <%= render "pipelines/define_panel", phase: define_phase, current_phase_kind: @pipeline.current_phase %>
  </div>
<% end %>

<%# Plan/Build/Review are materialized by Define's Workflow Planner — until then
    their columns would be empty and misleading, so hide them behind a
    placeholder (docs/execution-model.md — downstream columns hidden until
    planning). %>
<% visible_downstream = downstream_phases.select { |phase| phase.workflows.any? { |w| w.steps.exists? } } %>
<% if visible_downstream.any? %>
  <div class="mt-4 grid grid-cols-1 gap-4 md:grid-cols-3">
    <% visible_downstream.each do |phase| %>
      <%= render "pipelines/phase_column", phase: phase, current_phase_kind: @pipeline.current_phase %>
    <% end %>
  </div>
<% else %>
  <div class="mt-4 rounded-lg border border-dashed border-default bg-app px-6 py-8 text-center">
    <p class="text-sm font-medium text-muted">Phases appear after planning</p>
    <p class="mt-1 text-xs text-subtle">Plan, Build, and Review are laid out once Define's Workflow Planner runs.</p>
  </div>
<% end %>
