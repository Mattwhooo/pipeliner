<aside class="flex w-56 shrink-0 flex-col border-r border-default bg-surface">
  <div class="flex h-14 items-center gap-2 border-b border-default px-4">
    <span class="inline-block h-2.5 w-2.5 rounded-full bg-indigo-600"></span>
    <span class="text-sm font-semibold text-default">Pipeliner</span>
  </div>

  <nav class="flex-1 space-y-1 px-2 py-4">
    <% nav_items.each do |item| %>
      <% if item.path %>
        <%= link_to item.path,
              class: class_names(
                "flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium",
                item.active ? "bg-nav-active text-nav-active" : "text-muted hover:bg-surface-hover"
              ) do %>
          <span><%= item.label %></span>
        <% end %>
      <% else %>
        <span class="flex cursor-not-allowed items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-subtle"
              title="Coming soon">
          <%= item.label %>
        </span>
      <% end %>
    <% end %>
  </nav>

  <div class="flex items-center justify-between gap-2 border-t border-default p-3">
    <% if user_signed_in? %>
      <div class="min-w-0">
        <div class="truncate text-xs text-muted" title="<%= current_user.email %>"><%= current_user.email %></div>
        <%= button_to "Sign out", destroy_user_session_path, method: :delete,
              class: "mt-1 text-xs font-medium text-muted hover:text-default bg-transparent cursor-pointer" %>
      </div>
    <% end %>
    <%= render "shared/theme_toggle" %>
  </div>
</aside>
