<% content_for :title, "Workers · Pipeliner" %>

<div class="flex items-center justify-between">
  <h1 class="text-2xl font-semibold text-gray-900">Workers</h1>
</div>

<% if @workers.any? %>
  <div class="mt-8 overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
    <table class="min-w-full divide-y divide-gray-100">
      <thead>
        <tr>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500">Worker</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500">Status</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500">Backend</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500">Roles</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500">Concurrency</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500">Last heartbeat</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @workers.each do |worker| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4">
              <div class="text-sm font-medium text-gray-900"><%= worker.name.presence || worker.public_id %></div>
              <div class="font-mono text-xs text-gray-500"><%= worker.public_id %></div>
            </td>
            <td class="px-6 py-4"><%= status_badge(worker.status) %></td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= worker.backend %></td>
            <td class="px-6 py-4">
              <div class="flex flex-wrap gap-1">
                <% worker.supported_roles.each do |role| %>
                  <span class="rounded bg-gray-100 px-1.5 py-0.5 font-mono text-xs text-gray-700"><%= role %></span>
                <% end %>
              </div>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= worker.concurrency %></td>
            <td class="px-6 py-4 text-sm text-gray-500">
              <% if worker.last_heartbeat_at %>
                <time title="<%= worker.last_heartbeat_at %>"><%= time_ago_in_words(worker.last_heartbeat_at) %> ago</time>
              <% else %>
                —
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="mt-8 rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <div class="py-12 text-center">
      <p class="text-sm font-medium text-gray-900">No workers registered</p>
      <p class="mt-1 text-xs text-gray-500">
        Start a worker and it will self-register here. See <span class="font-mono">worker/README.md</span>.
      </p>
    </div>
  </div>
<% end %>
