<!DOCTYPE html>
<html class="h-full bg-app <%= "dark" if dark_theme? %>">
  <head>
    <%= render "shared/theme_init_script" %>
    <title><%= content_for(:title) || "Pipeliner" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full">
    <main class="flex min-h-full flex-col justify-center px-6 py-12">
      <div class="flex items-center justify-center gap-2 sm:mx-auto sm:w-full sm:max-w-sm">
        <div>
          <h1 class="text-center text-2xl font-semibold text-default">Pipeliner</h1>
          <p class="mt-1 text-center text-xs text-muted">Agentic development pipelines</p>
        </div>
        <%= render "shared/theme_toggle" %>
      </div>
      <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-sm">
        <%= render "shared/flash" %>
        <div class="rounded-lg border border-default bg-surface p-6 shadow-sm">
          <%= yield %>
        </div>
      </div>
    </main>
  </body>
</html>
