<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "Pipeliner" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full">
    <main class="flex min-h-full flex-col justify-center px-6 py-12">
      <div class="sm:mx-auto sm:w-full sm:max-w-sm">
        <h1 class="text-center text-2xl font-semibold text-gray-900">Pipeliner</h1>
        <p class="mt-1 text-center text-xs text-gray-500">Agentic development pipelines</p>
      </div>
      <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-sm">
        <%= render "shared/flash" %>
        <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
          <%= yield %>
        </div>
      </div>
    </main>
  </body>
</html>
